#!/usr/bin/env python3
"""tsdecomp: STL decomposition + stationarity + ACF/PACF for a univariate series."""
import argparse
import sys
from pathlib import Path

import matplotlib

matplotlib.use("Agg")
import matplotlib.pyplot as plt
import numpy as np
import pandas as pd
from statsmodels.graphics.tsaplots import plot_acf, plot_pacf
from statsmodels.tsa.seasonal import STL
from statsmodels.tsa.stattools import adfuller


FREQ_PERIOD = {"D": 7, "H": 24, "W": 52, "M": 12, "Q": 4, "B": 5, "T": 60, "min": 60}


def main() -> int:
    ap = argparse.ArgumentParser()
    ap.add_argument("--data", required=True)
    ap.add_argument("--date", required=True)
    ap.add_argument("--value", required=True)
    ap.add_argument("--period", type=int, default=0)
    ap.add_argument("--out", default="")
    args = ap.parse_args()

    p = Path(args.data)
    df = pd.read_csv(p) if p.suffix == ".csv" else pd.read_parquet(p)
    df[args.date] = pd.to_datetime(df[args.date])
    df = df[[args.date, args.value]].dropna().sort_values(args.date)
    s = df.set_index(args.date)[args.value].astype(float)

    inferred = pd.infer_freq(s.index)
    if inferred is None:
        # try resampling to most common diff
        diffs = s.index.to_series().diff().dropna().mode()
        if not diffs.empty:
            freq_td = diffs.iloc[0]
            s = s.asfreq(freq_td)
            inferred = pd.infer_freq(s.index)
    period = args.period or FREQ_PERIOD.get((inferred or "")[:1], 7)

    print(f"# tsdecomp on {args.value} from {args.data}")
    print(f"range:        {s.index.min()}  ->  {s.index.max()}")
    print(f"length:       {len(s):,}")
    print(f"inferred freq: {inferred}    period used: {period}")
    n_missing = s.isna().sum()
    if n_missing:
        print(f"missing values: {n_missing} (interpolating linearly)")
        s = s.interpolate()

    adf_raw = adfuller(s.dropna(), autolag="AIC")
    adf_d1 = adfuller(s.diff().dropna(), autolag="AIC")
    print(f"\n## ADF stationarity")
    print(f"raw:        stat={adf_raw[0]:.3f}  p={adf_raw[1]:.4g}")
    print(f"1st diff:   stat={adf_d1[0]:.3f}  p={adf_d1[1]:.4g}")

    stl = STL(s, period=period, robust=True).fit()

    out = args.out or f"/work/ts_{args.value}.png"
    fig, axes = plt.subplots(4, 1, figsize=(12, 10), sharex=True)
    axes[0].plot(s.index, s.values); axes[0].set_title(f"observed: {args.value}")
    axes[1].plot(stl.trend.index, stl.trend.values, color="C1"); axes[1].set_title("trend")
    axes[2].plot(stl.seasonal.index, stl.seasonal.values, color="C2"); axes[2].set_title(f"seasonal (period={period})")
    axes[3].plot(stl.resid.index, stl.resid.values, color="C3"); axes[3].set_title("residual")
    fig.tight_layout(); fig.savefig(out, dpi=110); plt.close(fig)
    print(f"\n## decomposition saved: {out}")

    acf_out = out.replace(".png", "_acf.png")
    fig, axes = plt.subplots(2, 1, figsize=(10, 6))
    plot_acf(s.dropna(), lags=min(40, len(s) // 4), ax=axes[0])
    plot_pacf(s.dropna(), lags=min(40, len(s) // 4), ax=axes[1], method="ywm")
    fig.tight_layout(); fig.savefig(acf_out, dpi=110); plt.close(fig)
    print(f"## ACF/PACF saved:    {acf_out}")

    seas_strength = max(0.0, 1 - np.var(stl.resid) / np.var(stl.seasonal + stl.resid))
    trend_strength = max(0.0, 1 - np.var(stl.resid) / np.var(stl.trend + stl.resid))
    print(f"\n## strengths (0-1)")
    print(f"trend:    {trend_strength:.3f}")
    print(f"seasonal: {seas_strength:.3f}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
