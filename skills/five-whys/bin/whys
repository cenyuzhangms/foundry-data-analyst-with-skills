#!/usr/bin/env python3
"""whys — emit a 5-Whys scaffold to stdout and to /work/whys/<slug>-<date>.md."""
from __future__ import annotations
import argparse
import datetime as dt
import re
import sys
from pathlib import Path


def slugify(s: str) -> str:
    s = s.lower().strip()
    s = re.sub(r"[^a-z0-9]+", "-", s)
    return s.strip("-")[:60] or "untitled"


TEMPLATE = """# 5-Whys: {symptom}

**Symptom (what was observed)**: {symptom}

| # | Why? | Answer |
|---|---|---|
| 1 | Why did this happen? | <TODO: most direct cause> |
| 2 | Why did THAT happen? | <TODO: one layer deeper> |
| 3 | Why did THAT happen? | <TODO: process or system layer> |
| 4 | Why did THAT happen? | <TODO: deeper systemic cause> |
| 5 | Why did THAT happen? | <TODO: root cause — should be testable / falsifiable> |

**Root cause**: <TODO: restate the row-5 answer in one sentence>

**Corrective action**: <TODO: ONE concrete change that addresses the root cause, not the symptom — prefer tooling/process changes over "be more careful">

**Owner**: <TODO: person/team>
**Verification**: <TODO: how we'll know the corrective action worked, with a metric and a window>

---

_Generated {timestamp} by `whys` skill. Replace every `<TODO: …>` with concrete content before sharing._
"""


def main(argv: list[str]) -> int:
    p = argparse.ArgumentParser()
    p.add_argument("symptom", help="the problem to drill into")
    p.add_argument("--out-dir", default="/work/whys")
    args = p.parse_args(argv)

    body = TEMPLATE.format(
        symptom=args.symptom,
        timestamp=dt.datetime.now().strftime("%Y-%m-%d %H:%M"),
    )

    out_dir = Path(args.out_dir)
    out_dir.mkdir(parents=True, exist_ok=True)
    out_path = out_dir / f"{slugify(args.symptom)}-{dt.date.today().isoformat()}.md"
    out_path.write_text(body, encoding="utf-8")

    sys.stdout.write(body)
    if not body.endswith("\n"):
        sys.stdout.write("\n")
    sys.stdout.write(f"\nsaved={out_path}\n")
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
